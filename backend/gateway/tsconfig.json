{
    "compilerOptions": {
        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "rootDir": "./src",
        "outDir": "./dist",

        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,

        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,

        "resolveJsonModule": true,
        "types": ["node"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
